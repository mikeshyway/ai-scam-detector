# Copy these values into Streamlit Cloud's Settings > Secrets.
# Do not commit real credentials to Git.

[webrtc]

# Option A: Twilio Network Traversal Service.
# The app requests short-lived TURN credentials and refreshes them hourly.
twilio_account_sid = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
twilio_auth_token = "replace-with-real-token"

# Option B: Static TURN provider or self-hosted coturn.
# Remove or leave these blank when using Twilio.
turn_urls = [
  "turn:turn.example.com:3478?transport=udp",
  "turn:turn.example.com:3478?transport=tcp",
  "turns:turn.example.com:443?transport=tcp",
]
turn_username = "replace-with-turn-username"
turn_credential = "replace-with-turn-password"
