# ==========================================================
# AI-FDS Deployment .gitignore
# Purpose:
# - Exclude raw/large training datasets and local-only files
# - Keep trained ML artifacts available for Streamlit deployment
# - Allow only runtime processed data that the live app actually needs
# ==========================================================

# ----------------------------------------------------------
# Python cache / compiled files
# ----------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.numba_cache/
**/.numba_cache/

# ----------------------------------------------------------
# Virtual environments
# ----------------------------------------------------------
.venv/
venv/
env/
ENV/

# ----------------------------------------------------------
# IDE / operating system files
# ----------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# ----------------------------------------------------------
# Environment variables and secrets
# ----------------------------------------------------------
.env
.env.*
!.env.example
.streamlit/secrets.toml

# ----------------------------------------------------------
# Notebook checkpoints
# ----------------------------------------------------------
.ipynb_checkpoints/

# ----------------------------------------------------------
# Raw datasets — never deploy or commit
# ----------------------------------------------------------
data/raw/
datasets/
dataset/
raw_data/
asvspoof_subset/

# Keep directory placeholders where needed
!data/raw/**/.gitkeep

# ----------------------------------------------------------
# Intermediate training data / extracted features
# ----------------------------------------------------------
data/interim/
data/features/
data/predictions/
data/cache/
cache/
tmp/
temp/

!data/interim/**/.gitkeep
!data/features/**/.gitkeep
!data/predictions/**/.gitkeep

# ----------------------------------------------------------
# Processed datasets
# Allow processed data for deployment testing
# ----------------------------------------------------------

# Keep processed datasets in Git for now
!data/processed/
!data/processed/**

# ----------------------------------------------------------
# Trained ML models and preprocessing artifacts
# IMPORTANT: these are intentionally NOT ignored
# Examples kept:
#   models/*.pkl
#   models/*.joblib
#   models/*.pickle
#   models/*.json
#   models/*.bin
#   models/*.onnx
# ----------------------------------------------------------

# ----------------------------------------------------------
# Generated reports and training outputs
# ----------------------------------------------------------
reports/metrics/*
reports/training_runs/
reports/figures/
reports/cache/

!reports/metrics/
!reports/metrics/.gitkeep
!reports/metrics/*.json

# ----------------------------------------------------------
# Large media / audio datasets
# Ignore globally, but allow app assets if explicitly placed
# under static/ or app/assets/
# ----------------------------------------------------------
*.flac
*.wav
*.mp3
*.ogg
*.m4a

!static/**/*.wav
!static/**/*.mp3
!static/**/*.ogg
!static/**/*.m4a
!app/assets/**/*.wav
!app/assets/**/*.mp3
!app/assets/**/*.ogg
!app/assets/**/*.m4a

# ----------------------------------------------------------
# Large dataset formats
# Ignore globally, but allow runtime processed data
# ----------------------------------------------------------
*.csv
*.tsv
*.parquet
*.feather

!data/processed/runtime/**/*.csv
!data/processed/runtime/**/*.tsv
!data/processed/runtime/**/*.parquet
!data/processed/runtime/**/*.feather

# Runtime processed artifacts are intentionally deployable.
!data/processed/**/*.csv
!data/processed/**/*.tsv
!data/processed/**/*.parquet
!data/processed/**/*.feather
!data/processed/**/*.flac
!data/processed/**/*.wav
!data/processed/**/*.mp3
!data/processed/**/*.ogg
!data/processed/**/*.m4a

# ----------------------------------------------------------
# NumPy training artifacts / feature dumps
# ----------------------------------------------------------
*.npy
*.npz

# ----------------------------------------------------------
# Local databases
# ----------------------------------------------------------
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Deployable report evidence store used by AI Report Generator.
!data/session_history.db

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
*.log
logs/

# ----------------------------------------------------------
# Temporary / backup files
# ----------------------------------------------------------
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# ----------------------------------------------------------
# Build / packaging output
# ----------------------------------------------------------
build/
dist/
*.egg-info/

# ----------------------------------------------------------
# Streamlit local state
# ----------------------------------------------------------
.streamlit/cache/
